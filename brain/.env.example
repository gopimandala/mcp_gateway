# Brain Services Configuration
# ALL VALUES ARE REQUIRED - No defaults provided

# Brain Server Port (AI Orchestration)
BRAIN_PORT=8000

# Guardrail Server Port (Content Safety)
GUARDRAIL_PORT=9090

# MCP Gateway URL (HTTP Wrapper) - Must be explicitly set
MCP_GATEWAY_URL=http://localhost:8021

# OpenAI Configuration - Required
OPENAI_KEY=your-openai-api-key
